---
import servicesData from '../../content/services.json';
const { sectionTag, sectionTitle, sectionDesc, services, ctaIcon, ctaTitle, ctaDesc, ctaButton } = servicesData;
---

<section class="section section--dark" id="services">
    <div class="container">
        <div class="section__header">
            <span class="section__tag section__tag--light">{sectionTag}</span>
            <h2 class="section__title section__title--light">{sectionTitle}</h2>
            <p class="section__desc section__desc--light">{sectionDesc}</p>
        </div>
        <div class="services__grid">
            {services.map(service => (
                <div class="dcard">
                    <i class={`fas ${service.icon}`}></i>
                    <h3>{service.title}</h3>
                    <p>{service.desc}</p>
                </div>
            ))}
            <div class="dcard dcard--cta">
                <i class={`fas ${ctaIcon}`}></i>
                <h3>{ctaTitle}</h3>
                <p>{ctaDesc}</p>
                <a href="#contact" class="btn btn--sm">{ctaButton}</a>
            </div>
        </div>
    </div>
</section>
