---
const services = [
  { icon: 'fa-id-card', title: 'Личные документы', desc: 'Свидетельства, дипломы, справки, доверенности и другие личные документы.' },
  { icon: 'fa-balance-scale', title: 'Юридическая документация', desc: 'Учредительные документы, решения суда, контракты, финансовая документация.' },
  { icon: 'fa-heartbeat', title: 'Медицинские документы', desc: 'Справки, заключения, аннотации к лекарственным препаратам.' },
  { icon: 'fa-headset', title: 'Устный перевод', desc: 'Последовательный и синхронный перевод на переговорах, конференциях и встречах.' },
  { icon: 'fa-passport', title: 'Консульские переводы', desc: 'Переводы для Консульства Республики Болгария в Молдове.' },
];
---

<section class="section section--dark" id="services">
    <div class="container">
        <div class="section__header">
            <span class="section__tag section__tag--light">Что я предлагаю</span>
            <h2 class="section__title section__title--light">Услуги перевода</h2>
            <p class="section__desc section__desc--light">Обратившись ко мне, Вы можете рассчитывать на высокое качество, соблюдение сроков и индивидуальный подход.</p>
        </div>
        <div class="services__grid">
            {services.map(service => (
                <div class="dcard">
                    <i class={`fas ${service.icon}`}></i>
                    <h3>{service.title}</h3>
                    <p>{service.desc}</p>
                </div>
            ))}
            <div class="dcard dcard--cta">
                <i class="fas fa-comment-dots"></i>
                <h3>Не нашли нужное?</h3>
                <p>Свяжитесь со мной — найдём решение!</p>
                <a href="#contact" class="btn btn--sm">Написать</a>
            </div>
        </div>
    </div>
</section>
