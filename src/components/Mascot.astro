---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="mascot" id="mascot" aria-label="Маскот-переводчик">
    <div class="mascot__tooltip">
        Привет! Нужен перевод?<br>Я помогу) напишите мне!
    </div>
    <div class="mascot__figure">
        <img src={`${base}/mascot.jpg`} alt="Маскот EuropeTrans — дружелюбный переводчик" width="100" height="100">
    </div>
</div>
