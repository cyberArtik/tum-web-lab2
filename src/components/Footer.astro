---
import footerData from '../../content/footer.json';
const { visible, logoText, logoAccent, description, phone, phoneHref, email, emailHref, copyright, legal } = footerData;
---

{visible && <footer class="footer tw-py-12">
    <div class="container">
        <div class="footer__row tw-flex tw-justify-between">
            <div class="footer__brand">
                <a href="#hero" class="nav__logo">{logoText}<span>{logoAccent}</span></a>
                <p>{description}</p>
            </div>
            <div class="footer__links">
                <a href={phoneHref}><i class="fas fa-phone-alt"></i> {phone}</a>
                <a href={emailHref}><i class="fas fa-envelope"></i> {email}</a>
            </div>
        </div>
        <div class="footer__bottom">
            <p>{copyright}</p>
            <p class="footer__legal">{legal}</p>
        </div>
    </div>
</footer>}
