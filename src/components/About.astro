---
const cards = [
  { icon: 'fa-gavel', title: 'Лицензированная деятельность', desc: 'В соответствии с Законом №264 от 11.12.2008 г. Республики Молдова' },
  { icon: 'fa-university', title: 'Аккредитация при Посольстве', desc: 'Аккредитованный переводчик при Посольстве Республики Болгария в Молдове' },
  { icon: 'fa-handshake', title: 'Прямое сотрудничество', desc: 'Без посредников, с индивидуальным подходом к каждому клиенту' },
];

const guarantees = [
  'Высокое качество',
  'Соблюдение сроков',
  'Разумная цена',
  'Конфиденциальность',
  'Долгосрочное сотрудничество',
  'Сохранность документов',
];
---

<section class="section" id="about">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">Знакомство</span>
            <h2 class="section__title">Обо мне</h2>
        </div>
        <div class="bento">
            <div class="bento__main">
                <p class="bento__lead">Если Вы ищете переводчика, с которым бы хотели работать напрямую — Вы попали по адресу.</p>
                <p>Я предоставляю услуги по переводу на румынский, болгарский и русский языки. Гарантирую конфиденциальность, высокое качество и соблюдение сроков.</p>
                <p>Переводами занимаюсь с 19-ти лет. Общий стаж работы — 22 года. Моё занятие — это моё призвание, а не просто способ заработка.</p>
            </div>
            {cards.map(card => (
                <div class="bento__card">
                    <i class={`fas ${card.icon}`}></i>
                    <h4>{card.title}</h4>
                    <p>{card.desc}</p>
                </div>
            ))}
            <div class="bento__guarantees">
                <h4>Мои гарантии</h4>
                <div class="gtags">
                    {guarantees.map(g => (
                        <span>✓ {g}</span>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>
