---
import aboutData from '../../content/about.json';
const { visible, sectionTag, sectionTitle, lead, paragraphs, cards, guaranteesTitle, guarantees } = aboutData;
---

{visible && <section class="section" id="about">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">{sectionTag}</span>
            <h2 class="section__title">{sectionTitle}</h2>
        </div>
        <div class="bento">
            <div class="bento__main">
                <p class="bento__lead">{lead}</p>
                {paragraphs.map(p => (
                    <p>{p}</p>
                ))}
            </div>
            {cards.map(card => (
                <div class="bento__card">
                    <i class={`fas ${card.icon}`}></i>
                    <h4>{card.title}</h4>
                    <p>{card.desc}</p>
                </div>
            ))}
            <div class="bento__guarantees">
                <h4>{guaranteesTitle}</h4>
                <div class="gtags">
                    {guarantees.map(g => (
                        <span>✓ {g}</span>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>}
