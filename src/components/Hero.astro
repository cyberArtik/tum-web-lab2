---
import heroData from '../../content/hero.json';
const { visible, badge, title, titleEmphasis, description, ctaPrimary, ctaSecondary, languages, stats } = heroData;
---

{visible && <section class="hero tw-min-h-screen tw-flex tw-items-center" id="hero">
    <div class="container hero__inner">
        <div class="hero__text">
            <span class="badge tw-inline-block tw-rounded-full">{badge}</span>
            <h1 class="hero__title">{title}<br><em>{titleEmphasis}</em></h1>
            <div class="hero__langs">
                {languages.map(lang => (
                    <span>
                        <img src={`https://flagcdn.com/w40/${lang.flag}.png`} alt={lang.alt} width="20" height="14" />
                        {lang.name}
                    </span>
                ))}
            </div>
            <p class="hero__desc">{description}</p>
            <div class="hero__cta-row tw-flex tw-flex-wrap tw-gap-3">
                <a href="#contact" class="btn btn--primary">{ctaPrimary}</a>
                <a href="#services" class="btn btn--outline">{ctaSecondary}</a>
            </div>
        </div>
        <div class="hero__stats">
            {stats.map(stat => (
                <div class="stat">
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                </div>
            ))}
        </div>
    </div>
</section>}
