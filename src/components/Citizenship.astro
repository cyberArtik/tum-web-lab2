---
const ways = [
  { icon: 'fa-dna', title: 'По происхождению', desc: 'Болгарские корни в свидетельстве о рождении или у родителей.' },
  { icon: 'fa-home', title: 'По натурализации', desc: 'Проживание в Болгарии не менее 5 лет, знание языка и легальный доход.' },
  { icon: 'fa-chart-line', title: 'Через инвестиции', desc: 'Инвестиции от 600 000 левов с последующим гражданством.' },
  { icon: 'fa-heart', title: 'По привилегиям', desc: 'Брак с гражданином Болгарии (3+ лет) или статус беженца.' },
];

const steps = [
  { num: 1, title: 'Подача в ДАБЧ', time: '≈ до 2,5 месяцев' },
  { num: 2, title: 'Удостоверение', time: '≈ 3 дня в Софии' },
  { num: 3, title: 'Собеседование', time: '10–15 вопросов' },
  { num: 4, title: 'Гражданство', time: 'Финальный этап' },
];

const faqs = [
  { q: 'Кто может претендовать на болгарское гражданство?', a: 'Лица, чьи родители (или один из родителей) являются болгарами или гагаузами по национальности, а также лица, чьи родители являются гражданами Республики Болгария.' },
  { q: 'Сколько длится вся процедура оформления?', a: 'Общая продолжительность процедуры оформления болгарского гражданства составляет 3–4 года.' },
  { q: 'Где можно подать документы?', a: 'Документы можно подать в ДАБЧ в Софии или через дипломатические миссии: Консульство в Кишинёве (ул. Еминеску, 4) или Консульство в Тараклии.' },
  { q: 'Какие языки доступны для перевода?', a: 'Румынский, болгарский и русский языки.' },
];
---

<section class="section section--soft" id="citizenship">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">Дополнительная услуга</span>
            <h2 class="section__title">Болгарское гражданство</h2>
            <p class="section__desc">Паспорт Болгарии — безвизовые поездки в 169 стран мира, включая страны ЕС, Канаду, Новую Зеландию и другие.</p>
        </div>
        <div class="cit__ways">
            {ways.map(way => (
                <div class="cway">
                    <span class="cway__icon"><i class={`fas ${way.icon}`}></i></span>
                    <h4>{way.title}</h4>
                    <p>{way.desc}</p>
                </div>
            ))}
        </div>

        <h3 class="steps__title">Этапы оформления (по происхождению)</h3>
        <div class="steps__row">
            {steps.map((step, i) => (
                <>
                    {i > 0 && <div class="step__arrow"><i class="fas fa-chevron-right"></i></div>}
                    <div class="step">
                        <div class="step__num">{step.num}</div>
                        <h4>{step.title}</h4>
                        <span>{step.time}</span>
                    </div>
                </>
            ))}
        </div>

        <h3 class="steps__title" style="margin-top: 56px;">Часто задаваемые вопросы</h3>
        <div class="faq">
            {faqs.map(faq => (
                <details class="faq__item">
                    <summary class="faq__q">{faq.q}</summary>
                    <p class="faq__a">{faq.a}</p>
                </details>
            ))}
        </div>
    </div>
</section>
