---
import processData from '../../content/process.json';
const { sectionTag, sectionTitle, steps } = processData;
---

<section class="section" id="process">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">{sectionTag}</span>
            <h2 class="section__title">{sectionTitle}</h2>
        </div>
        <div class="proc__row">
            {steps.map(step => (
                <div class="proc">
                    <span class="proc__num">{step.num}</span>
                    <h4>{step.title}</h4>
                    <p>{step.desc}</p>
                </div>
            ))}
        </div>
    </div>
</section>
