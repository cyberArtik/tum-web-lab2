---
const steps = [
  { num: '01', title: 'Отправьте заказ', desc: 'Отправьте документ по электронной почте или через форму на сайте.' },
  { num: '02', title: 'Получите оценку', desc: 'Я просмотрю документ и сообщу стоимость работы и сроки выполнения.' },
  { num: '03', title: 'Перевод', desc: 'Выполняю перевод с вниманием к деталям, терминологии и стилистике.' },
  { num: '04', title: 'Готовый результат', desc: 'Вы получаете качественный перевод в оговорённые сроки.' },
];
---

<section class="section" id="process">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">Просто и удобно</span>
            <h2 class="section__title">Порядок работы</h2>
        </div>
        <div class="proc__row">
            {steps.map(step => (
                <div class="proc">
                    <span class="proc__num">{step.num}</span>
                    <h4>{step.title}</h4>
                    <p>{step.desc}</p>
                </div>
            ))}
        </div>
    </div>
</section>
