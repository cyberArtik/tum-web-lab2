---
import contactData from '../../content/contact.json';
const { visible, sectionTag, sectionTitle, subjects, formLabels, contactInfo } = contactData;
---

{visible && <section class="section section--dark" id="contact">
    <div class="container">
        <div class="section__header">
            <span class="section__tag section__tag--light">{sectionTag}</span>
            <h2 class="section__title section__title--light">{sectionTitle}</h2>
        </div>
        <div class="contact__grid">
            <form class="contact-form" action="#" method="post" novalidate>
                <div class="form__row">
                    <div class="form__group">
                        <label for="cName">{formLabels.name}</label>
                        <input type="text" id="cName" name="name" placeholder={formLabels.namePlaceholder} required>
                    </div>
                    <div class="form__group">
                        <label for="cEmail">{formLabels.email}</label>
                        <input type="email" id="cEmail" name="email" placeholder={formLabels.emailPlaceholder} required>
                    </div>
                </div>
                <div class="form__group">
                    <label for="cSubject">{formLabels.subject}</label>
                    <select id="cSubject" name="subject">
                        <option value="">{formLabels.subjectPlaceholder}</option>
                        {subjects.map(s => (
                            <option value={s.value}>{s.label}</option>
                        ))}
                    </select>
                </div>
                <div class="form__group">
                    <label for="cMsg">{formLabels.message}</label>
                    <textarea id="cMsg" name="message" rows="4" placeholder={formLabels.messagePlaceholder} required></textarea>
                </div>
                <button type="submit" class="btn btn--light btn--block">{formLabels.submit}</button>
            </form>
            <div class="contact__info">
                {contactInfo.map(ci => (
                    <div class="ci">
                        <i class={`fas ${ci.icon}`}></i>
                        <div>
                            <strong>{ci.label}</strong>
                            {ci.isLink ? (
                                <a href={ci.href} {...(ci.external ? { target: '_blank' } : {})}>{ci.value}</a>
                            ) : (
                                <span>{ci.value}</span>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>}
