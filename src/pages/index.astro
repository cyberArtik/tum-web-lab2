---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MobileBanner from '../components/MobileBanner.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Citizenship from '../components/Citizenship.astro';
import Process from '../components/Process.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import siteSettings from '../../content/siteSettings.json';
---

<Layout title={siteSettings.title} description={siteSettings.description}>
    <Hero />
    <MobileBanner />
    <About />
    <Services />
    <Citizenship />
    <Process />
    <Testimonials />
    <Contact />
</Layout>
