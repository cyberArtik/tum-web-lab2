---
import citData from '../../content/citizenship.json';
const { visible, sectionTag, sectionTitle, sectionDesc, ways, stepsTitle, steps, faqTitle, faqs } = citData;
---

{visible && <section class="section section--soft" id="citizenship">
    <div class="container">
        <div class="section__header">
            <span class="section__tag">{sectionTag}</span>
            <h2 class="section__title">{sectionTitle}</h2>
            <p class="section__desc">{sectionDesc}</p>
        </div>
        <div class="cit__ways">
            {ways.map(way => (
                <div class="cway">
                    <span class="cway__icon"><i class={`fas ${way.icon}`}></i></span>
                    <h4>{way.title}</h4>
                    <p>{way.desc}</p>
                </div>
            ))}
        </div>

        <h3 class="steps__title">{stepsTitle}</h3>
        <div class="steps__row">
            {steps.map((step, i) => (
                <>
                    {i > 0 && <div class="step__arrow"><i class="fas fa-chevron-right"></i></div>}
                    <div class="step">
                        <div class="step__num">{step.num}</div>
                        <h4>{step.title}</h4>
                        <span>{step.time}</span>
                    </div>
                </>
            ))}
        </div>

        <h3 class="steps__title" style="margin-top: 56px;">{faqTitle}</h3>
        <div class="faq">
            {faqs.map(faq => (
                <details class="faq__item">
                    <summary class="faq__q">{faq.q}</summary>
                    <p class="faq__a">{faq.a}</p>
                </details>
            ))}
        </div>
    </div>
</section>}
