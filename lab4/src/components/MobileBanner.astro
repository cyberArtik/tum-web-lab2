---
import bannerData from '../../content/mobileBanner.json';
const { visible, title, description } = bannerData;
---

{visible && <section class="mobile-only-banner">
    <div class="container">
        <div class="mobile-only-banner__inner tw-text-center tw-py-6">
            <i class="fas fa-mobile-alt tw-text-2xl tw-mb-2" style="color:var(--c-mid)"></i>
            <h2 class="tw-font-serif tw-text-xl" style="color:var(--c-deep);font-family:var(--font-serif)">{title}</h2>
            <p class="tw-text-sm" style="color:var(--c-text-light)">{description}</p>
        </div>
    </div>
</section>}
